{
    "name": "psc-acme/driver-auth",
    "description": "Package driver-auth for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\DriverAuth\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "psr/cache": "^3.0",
        "league/csv": "^9.0"
    },
    "require-dev": {
        "phpstan/phpstan-symfony": "^1.0",
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}